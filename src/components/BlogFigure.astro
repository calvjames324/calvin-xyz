---
import { Image } from 'astro:assets';

interface Props {
	src: ImageMetadata | string;
	alt: string;
	caption?: string;
	width?: number;
	height?: number;
}

const {
	src,
	alt,
	caption,
	width = 1200,
	height = 720,
} = Astro.props;
---

<figure class="my-10">
	<Image
		src={src}
		alt={alt}
		width={width}
		height={height}
		class="w-full rounded-lg shadow-md"
	/>
	{caption && (
		<figcaption class="mt-3 text-center text-sm italic text-(--primary)/70">
			{caption}
		</figcaption>
	)}
</figure>
